# =============================================================================
# WrytrsBlock — environment template
# Copy to .env.local and fill in values.
# =============================================================================

# Supabase — required for auth + persistence.
# Find these under: Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only set for server-side admin tasks (cron, webhooks).
# Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: where signed-in users land after auth callback.
NEXT_PUBLIC_AUTH_REDIRECT_PATH=/home

# Optional: canonical site URL used to build "Open Block" links in emails.
NEXT_PUBLIC_SITE_URL=https://www.wrytrsblock.com

# Optional: Resend — required to actually send activity-notification emails
# (chat messages, file uploads, voice notes, Block joins, split sheet updates).
# Without these, notifications still work in-app; email sending just no-ops.
# Get a key at https://resend.com and verify a sending domain there.
RESEND_API_KEY=
RESEND_FROM_EMAIL=WrytrsBlock <notifications@wrytrsblock.com>
