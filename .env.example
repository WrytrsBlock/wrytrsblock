# =============================================================================
# WrytrsBlock — environment template
# Copy to .env.local and fill in values.
# =============================================================================

# Supabase — required for auth + persistence.
# Find these under: Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only set for server-side admin tasks (cron, webhooks).
# Never expose to the client. Required for the 24h creator follow-up cron
# (app/api/cron/follow-up-emails) to actually run — without it, that route
# no-ops (logs only) instead of sending anything.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: where signed-in users land after auth callback.
NEXT_PUBLIC_AUTH_REDIRECT_PATH=/home

# Optional: canonical site URL used to build "Open Block" links in emails.
NEXT_PUBLIC_SITE_URL=https://www.wrytrsblock.com

# Optional: Resend — required to actually send activity-notification emails
# (chat messages, file uploads, voice notes, Block joins, split sheet updates).
# Without these, notifications still work in-app; email sending just no-ops.
# Get a key at https://resend.com and verify a sending domain there.
RESEND_API_KEY=
RESEND_FROM_EMAIL=WrytrsBlock <notifications@wrytrsblock.com>

# Optional: where the internal "🎉 New Creator Joined" notification email is
# sent whenever someone finishes onboarding. Without this, that email is
# skipped (logged only) — the new creator's own welcome email still sends.
ADMIN_NOTIFICATION_EMAIL=

# Optional: verifies requests to app/api/cron/* actually came from Vercel's
# own cron scheduler (Vercel automatically sends this as a Bearer token).
# Without it, those routes accept unauthenticated requests — fine for local
# dev, not recommended once deployed.
CRON_SECRET=

# Optional: OpenAI — required for the Songwriter "✨ Inspire" AI assistant
# (Continue Writing / Rewrite This Section / Generate Hook Ideas / Make
# Lyrics More Emotional). Without this, Inspire shows a friendly "not
# available yet" message instead of erroring — the rest of Songwriter works
# fully without it.
OPENAI_API_KEY=

# Optional: Upstash Redis — backs rate limiting on abuse-prone actions
# (sending Block Requests, the paid Inspire assistant). Get a free database
# at https://console.upstash.com (REST URL + token, under the database's
# "REST API" tab). Without these, those actions run with no throttle — fine
# for local dev, not recommended in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
